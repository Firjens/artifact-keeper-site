---
const features = [
  {
    icon: "\u{1F6E1}\uFE0F",
    title: "Vulnerability Scanning",
    description: "Trivy + OpenSCAP integrated, automatic CVE alerts",
  },
  {
    icon: "\u{1F512}",
    title: "Access Control",
    description: "Fine-grained permissions, RBAC, API keys",
  },
  {
    icon: "\u{1F4CB}",
    title: "Audit Logging",
    description: "Full audit trail of all actions",
  },
  {
    icon: "\u{1F511}",
    title: "Artifact Signing",
    description: "GPG and cosign support for provenance verification",
  },
  {
    icon: "\u{1F91A}",
    title: "SSO",
    description: "LDAP, SAML, OIDC out of the box",
  },
  {
    icon: "\u{1F4E6}",
    title: "SBOM & Dependency-Track",
    description: "CycloneDX SBOM generation, dependency analysis",
  },
  {
    icon: "\u{1F50D}",
    title: "OpenSCAP Compliance",
    description: "SCAP policy scanning for container images",
  },
  {
    icon: "\u{1F510}",
    title: "Encryption",
    description: "At-rest and in-transit encryption standard",
  },
];
---

<section id="security" class="bg-brand-dark text-white py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-12">
      Security built in, not bolted on
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature) => (
        <div class="p-6">
          <div class="text-3xl mb-3">{feature.icon}</div>
          <h3 class="font-bold text-lg mb-1">{feature.title}</h3>
          <p class="text-white/70 text-sm">{feature.description}</p>
        </div>
      ))}
    </div>

    <div class="bg-white/10 border-l-4 border-brand p-6 rounded mt-8 max-w-4xl mx-auto">
      <p class="text-white/90">
        Other registries charge $30,000+/year for security scanning. We include it because securing your supply chain shouldn't be a luxury.
      </p>
    </div>

    <p class="text-center text-white/50 text-xs mt-6 max-w-4xl mx-auto">
      Security scanning powered by <a href="https://trivy.dev/" class="text-white/70 underline hover:text-white">Trivy</a>,
      <a href="https://www.open-scap.org/" class="text-white/70 underline hover:text-white">OpenSCAP</a>,
      and <a href="https://dependencytrack.org/" class="text-white/70 underline hover:text-white">OWASP Dependency-Track</a> &mdash; all open-source.
    </p>
  </div>
</section>
